{
  "publisher": "nangmanhunter-publisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/nangmanhunter/text-wrap.git"
  },


  "name": "text-wrap",
  "displayName": "text-wrap",
  "description": "",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "text-wrap-quotes-double", "category": "Text.Wrap.Quotes.Double", "title": "\"ㅇㅇ\"" },
      { "command": "text-wrap-quotes-double-comma", "category": "Text.Wrap.Quotes.Double.Comma", "title": "\"ㅇㅇ\"," },
      { "command": "text-wrap-quotes-single", "category": "Text.Wrap.Quotes.Single", "title": "'ㅇㅇ'" },
      { "command": "text-wrap-backtick", "category": "Text.Wrap.Backtick", "title": "`ㅇㅇ`" },
      { "command": "text-wrap-brackets-round", "category": "Text.Wrap.Brackets.Round", "title": "(ㅇㅇ)" },
      { "command": "text-wrap-brackets-square", "category": "Text.Wrap.Brackets.Square", "title": "[ㅇㅇ]" },
      { "command": "text-wrap-brackets-curly", "category": "Text.Wrap.Brackets.Curly", "title": "{ㅇㅇ}" },
      { "command": "text-wrap-brackets-angle", "category": "Text.Wrap.Brackets.Angle", "title": "<ㅇㅇ>" }

    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
