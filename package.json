{
  "publisher": "nangmanhunter-publisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/nangmanhunter/text-wrap.git"
  },
  "name": "text-wrap",
  "displayName": "text-wrap",
  "description": "",
  "version": "1.2.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "text-wrap-quotes-double",
        "category": "text-wrap-quotes-double",
        "title": "\"ㅇㅇ\""
      },
      {
        "command": "text-wrap-quotes-double-comma",
        "category": "text-wrap-quotes-double-comma",
        "title": "\"ㅇㅇ\","
      },
      {
        "command": "text-wrap-quotes-single",
        "category": "text-wrap-quotes-single",
        "title": "'ㅇㅇ'"
      },
      {
        "command": "text-wrap-backtick",
        "category": "text-wrap-backtick",
        "title": "`ㅇㅇ`"
      },
      {
        "command": "text-wrap-backtick-comma",
        "category": "text-wrap-backtick-comma",
        "title": "`ㅇㅇ`,"
      },
      {
        "command": "text-wrap-brackets-round",
        "category": "text-wrap-brackets-round",
        "title": "(ㅇㅇ)"
      },
      {
        "command": "text-wrap-brackets-round-comma",
        "category": "text-wrap-brackets-round-comma",
        "title": "(ㅇㅇ),"
      },
      {
        "command": "text-wrap-brackets-square",
        "category": "text-wrap-brackets-square",
        "title": "[ㅇㅇ]"
      },
      {
        "command": "text-wrap-brackets-square-comma",
        "category": "text-wrap-brackets-square-comma",
        "title": "[ㅇㅇ],"
      },
      {
        "command": "text-wrap-brackets-curly",
        "category": "text-wrap-brackets-curly",
        "title": "{ㅇㅇ}"
      },
      {
        "command": "text-wrap-brackets-curly-comma",
        "category": "text-wrap-brackets-curly-comma",
        "title": "{ㅇㅇ},"
      },
      {
        "command": "text-wrap-brackets-angle",
        "category": "text-wrap-brackets-angle",
        "title": "<ㅇㅇ>"
      },
      {
        "command": "text-wrap-brackets-angle-comma",
        "category": "text-wrap-brackets-angle-comma",
        "title": "<ㅇㅇ>,"
      },
      {
        "command": "text-wrap-notrailing-quotes-double-comma",
        "category": "text-wrap-notrailing-quotes-double-comma",
        "title": "\"ㅇㅇ\", ... \"ㅇㅇ\""
      },
      {
        "command": "text-wrap-notrailing-quotes-single-comma",
        "category": "text-wrap-notrailing-quotes-single-comma",
        "title": "'ㅇㅇ', ... 'ㅇㅇ'"
      },
      {
        "command": "text-wrap-notrailing-backtick-comma",
        "category": "text-wrap-notrailing-backtick-comma",
        "title": "`ㅇㅇ`, ... `ㅇㅇ`"
      },
      {
        "command": "text-wrap-notrailing-brackets-round-comma",
        "category": "text-wrap-notrailing-brackets-round-comma",
        "title": "(ㅇㅇ), ... (ㅇㅇ)"
      },
      {
        "command": "text-wrap-notrailing-brackets-square-comma",
        "category": "text-wrap-notrailing-brackets-square-comma",
        "title": "[ㅇㅇ], ... [ㅇㅇ]"
      },
      {
        "command": "text-wrap-notrailing-brackets-curly-comma",
        "category": "text-wrap-notrailing-brackets-curly-comma",
        "title": "{ㅇㅇ}, ... {ㅇㅇ}"
      },
      {
        "command": "text-wrap-notrailing-brackets-angle-comma",
        "category": "text-wrap-notrailing-brackets-angle-comma",
        "title": "<ㅇㅇ>, ... <ㅇㅇ>"
      },
      {
        "command": "text-wrap-powershell-newitem-markdown",
        "category": "text-wrap-powershell-newitem-markdown",
        "title": "ni ㅇㅇ.md"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
